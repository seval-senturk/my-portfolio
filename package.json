    "lucide-react": "^1.21.0",
    "next": "^15.5.19",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanitize-html": "^2.17.5",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "^9",
    "eslint-config-next": "^15.5.19",
    "eslint-config-prettier": "^10.1.8",
    "playwright": "^1.61.1",
    "prettier": "^3.8.4",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
