# Site
# Local: http://localhost:3000
# Production (Vercel): your real deployment URL, e.g. https://my-portfolio-abc123.vercel.app
# Do NOT use placeholder text like your-domain.com — copy the URL from Vercel → Project → Domains
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Database — Neon PostgreSQL (development & production)
# 1. Create a project at https://neon.tech
# 2. Copy the pooled connection string for application runtime
# 3. Optional: use the direct (non-pooled) URL for Prisma migrations via DIRECT_URL
#
# Example (pooled — recommended for serverless / Next.js):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
#
# Example (direct — optional, for migrations only):
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Auth.js
# Production: same base URL as NEXT_PUBLIC_SITE_URL (no trailing slash)
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Admin seed (development only — do not commit real credentials)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# Google OAuth (optional — admin login)
# 1. Create OAuth client: Google Cloud Console → Credentials → OAuth 2.0 Client (Web)
# 2. Authorized JavaScript origins:
#    - http://localhost:3000
#    - https://YOUR-VERCEL-URL.vercel.app
# 3. Authorized redirect URIs (exact paths):
#    - http://localhost:3000/api/auth/callback/google
#    - https://YOUR-VERCEL-URL.vercel.app/api/auth/callback/google
# 4. Set the same production base URL in Vercel for AUTH_URL and NEXT_PUBLIC_SITE_URL
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# Cloudinary (production media storage — optional in development; local fallback used when unset)
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# MAINTENANCE_MODE="true"
# EMAIL_PROVIDER="stub"
# Supported email providers (architecture ready): stub | resend | smtp | sendgrid
# RESEND_API_KEY=""
# SMTP_HOST=""
# SMTP_PORT=""
# SMTP_USER=""
# SMTP_PASSWORD=""
